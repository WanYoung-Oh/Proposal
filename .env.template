# ══════════════════════════════════════════════════════════════════
# 공공정보화 RFP 제안전략 수립 시스템 — 환경 변수 템플릿
# 복사: cp .env.template .env  →  .env는 .gitignore에서 제외됨
# ══════════════════════════════════════════════════════════════════

# ── LLM API 키 ────────────────────────────────────────────────────
# Anthropic (Claude API — STEP 5·7 전략 추론 + tags 추출 스크립트)
ANTHROPIC_API_KEY=sk-ant-...

# Upstage (Solar Pro API — OpenAI 호환, STEP 5·7 대안)
SOLAR_API_KEY=up_...

# ── 로컬 LLM 서버 (Mac Mini 운영) ────────────────────────────────
# MLX 1순위: mlx_lm.server --model mlx-community/Qwen3.5-9B-4bit --port 11434
# Ollama 대안: ollama serve  (Qwen3.5 레지스트리 등록 확인 후 전환)
LOCAL_LLM_BASE_URL=http://localhost:11434

# ── Qdrant 벡터 DB (Mac Mini Docker, 상시) ───────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── 세션 체크포인트 (SqliteSaver) ─────────────────────────────────
# LangGraph thread_id 기반 세션 영속 — 브라우저 재접속 후 이어하기
SESSIONS_DB_PATH=data/sessions.db

# ── 데이터 경로 (기본값 사용 시 생략 가능) ────────────────────────
# DATA_DIR=data/projects
# METHODOLOGY_DIR=data/methodology
# VECTORSTORE_PATH=data/vectorstore

# ══════════════════════════════════════════════════════════════════
# RTX 3090 초기 빌드 전용 (.env 또는 셸 export — 빌드 후 불필요)
# Mac Mini에서 Qdrant Docker 먼저 기동 후 아래 IP로 원격 업로드
# ══════════════════════════════════════════════════════════════════
# QDRANT_HOST=192.168.x.x    # Mac Mini IP (빌드 시에만 override)
# QDRANT_PORT=6333
